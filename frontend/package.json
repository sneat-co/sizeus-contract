{
	"name": "@sneat/extension-sizeus-contract",
	"version": "0.0.6",
	"description": "Frozen cross-repo contract surface (shared DTOs, consts, briefs) for the sizeus Sneat extension",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/sneat-co/ext-sizeus.git"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"prepublishOnly": "pnpm build",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"peerDependencies": {
		"@angular/core": "^21.0.0",
		"@sneat/core": "^0.22.0",
		"@sneat/data": "^0.22.0",
		"@sneat/dto": "^0.22.0",
		"@sneat/space-models": "^0.22.0",
		"rxjs": "^7.0.0"
	},
	"devDependencies": {
		"@nx/js": "22.7.5",
		"@angular/core": "21.2.9",
		"@sneat/core": "0.22.1",
		"@sneat/data": "^0.22.0",
		"@sneat/dto": "^0.22.0",
		"@sneat/space-models": "0.22.1",
		"rxjs": "7.8.2",
		"nx": "22.7.5",
		"typescript": "~5.9.3",
		"vitest": "4.1.0"
	}
}
